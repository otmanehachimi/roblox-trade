<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RBLX Trade Hub</title>

<style>
body {
    font-family: Arial;
    margin: 0;
    background: #0b1220;
    color: white;
}

header {
    background: #2563eb;
    padding: 20px;
    text-align: center;
}

.container {
    max-width: 900px;
    margin: auto;
    padding: 20px;
}

.card {
    background: #111827;
    padding: 15px;
    border-radius: 10px;
    margin-bottom: 15px;
}

input, textarea {
    width: 100%;
    padding: 10px;
    margin-top: 10px;
    border-radius: 8px;
    border: none;
}

button {
    margin-top: 10px;
    padding: 10px;
    width: 100%;
    background: #22c55e;
    border: none;
    color: white;
    font-weight: bold;
    cursor: pointer;
    border-radius: 8px;
}

.trade {
    background: #1f2937;
    padding: 10px;
    border-radius: 8px;
    margin-top: 10px;
}

.small {
    font-size: 12px;
    color: #aaa;
}

.delete {
    background: red;
    margin-top: 5px;
}
</style>
</head>

<body>

<header>
    <h1>🎮 RBLX Trade Hub</h1>
    <p>Échange d’objets Roblox</p>
</header>

<div class="container">

    <div class="card">
        <h2>Créer une offre</h2>
        <input id="user" placeholder="Ton pseudo Roblox">
        <input id="game" placeholder="Jeu (ex: Blox Fruits, Adopt Me)">
        <textarea id="offer" placeholder="Décris ton échange"></textarea>
        <button onclick="addTrade()">Publier</button>
    </div>

    <h2>📦 Offres disponibles</h2>
    <div id="list"></div>

</div>

<script>
let trades = JSON.parse(localStorage.getItem("trades")) || [];

function render() {
    let list = document.getElementById("list");
    list.innerHTML = "";

    trades.forEach((t, i) => {
        list.innerHTML += `
        <div class="trade">
            <b>${t.user}</b> - <span class="small">${t.game}</span>
            <p>${t.offer}</p>
            <button class="delete" onclick="removeTrade(${i})">Supprimer</button>
        </div>
        `;
    });
}

function addTrade() {
    let user = document.getElementById("user").value;
    let game = document.getElementById("game").value;
    let offer = document.getElementById("offer").value;

    if(!user || !game || !offer) return alert("Remplis tout !");

    trades.push({user, game, offer});
    localStorage.setItem("trades", JSON.stringify(trades));

    document.getElementById("user").value = "";
    document.getElementById("game").value = "";
    document.getElementById("offer").value = "";

    render();
}

function removeTrade(i) {
    trades.splice(i, 1);
    localStorage.setItem("trades", JSON.stringify(trades));
    render();
}

render();
</script>

</body>
</html>
